# Build 产物
.gradle/
.idea/
build/
app/build/
.kotlin/
*.iml

# 本地配置（不跟踪）
local.properties

# Release 签名密钥（不入仓；正式发版请用项目专属密钥并单独管理）
app/*.keystore
app/*.jks
app/keystore.properties

# 第三方依赖（应放 maven/google 而不是仓库里）
third_party/
app/libs/

# 内部工具目录（不属于项目）
.omc/
.omx/state/
.omx/logs/
.omx/drafts/
.omx/external/        # clone 来的第三方仓库不进入本仓库

# 临时调试产物
.omx/*.png            # 根目录临时截图
.omx/*.ps1            # 临时 powershell 脚本
.omx/df_*.png         # M3 期间调试截图前缀

# 调研期 M0 临时产物（.md 决策文档和 .json 脱敏数据保留）
.omx/m0/private/      # 含真实用户 cookie/db（敏感）
.omx/m0/code/         # 反编译的第三方 JS
.omx/m0/*.png         # 临时截图
.omx/m0/*.xml         # UI dump
.omx/m0/*.log         # 抓包日志
.omx/m0/*socket*.txt
.omx/m0/*logcat*.txt
.omx/m0/events-*.txt
.omx/m0/dumpsys-*.txt

# 敏感数据（通用规则）
*.bin
*.db
captures/
logs/
.omx/interface-capture/private/  # V2 接口抓取 token/cookie 私有目录

# 临时二进制
*.bin
