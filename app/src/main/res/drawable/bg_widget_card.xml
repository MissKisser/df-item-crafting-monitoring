<?xml version="1.0" encoding="utf-8"?>
<!-- Widget 卡片底层：深蓝→紫黑对角渐变 + 12dp 大圆角，玻璃质感。 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#1B2440"
        android:centerColor="#1A1F38"
        android:endColor="#231538"
        android:type="linear" />
    <corners android:radius="12dp" />
</shape>
