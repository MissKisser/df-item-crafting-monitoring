<?xml version="1.0" encoding="utf-8"?>
<!--
  APP 启动器图标 - 背景层
  深色径向渐变（中心亮、边缘暗），与 widget 玻璃风卡片色调统一。
  独立原创，不复用第三方商标素材。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="72dp"
        android:centerX="0.5"
        android:centerY="0.4"
        android:startColor="#3F4D7A"
        android:centerColor="#222B4D"
        android:endColor="#0F1530" />
</shape>
