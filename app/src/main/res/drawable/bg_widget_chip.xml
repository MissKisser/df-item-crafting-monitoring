<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget 头部图标圆形徽章背景：
  - 与卡片主背景 bg_widget_card 同色系但更亮，形成"金属徽章"观感
  - 4dp 内边距保证小尺寸下图标仍居中
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:type="radial"
        android:gradientRadius="12dp"
        android:startColor="#3A4870"
        android:endColor="#1F2742" />
    <stroke
        android:width="1dp"
        android:color="#22FFFFFF" />
</shape>
