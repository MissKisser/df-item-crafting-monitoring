<?xml version="1.0" encoding="utf-8"?>
<!-- 组合 Widget 4x2：半包围式——4 工位(左右 + 下)包围中央盈亏。 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_widget_card"
    android:paddingTop="7dp"
    android:paddingBottom="7dp"
    android:paddingStart="9dp"
    android:paddingEnd="9dp">

    <!-- 标题栏：制造图标 + 制造 + 金币徽章 + 盈亏 + 账号 + 刷新 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="5dp">

        <ImageView
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_forge"
            android:importantForAccessibility="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="制造"
            android:textColor="@color/widget_text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="3dp"
            android:text="/"
            android:textColor="@color/widget_text_muted"
            android:textSize="11sp"
            android:singleLine="true" />

        <FrameLayout
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:background="@drawable/bg_widget_chip">

            <ImageView
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_coin"
                android:importantForAccessibility="no" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="3dp"
            android:text="盈亏"
            android:textColor="@color/widget_text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true" />

        <TextView
            android:id="@+id/account_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:gravity="start"
            android:text="待同步"
            android:textColor="@color/widget_text_secondary"
            android:textSize="9sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <ImageView
            android:id="@+id/btn_refresh"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:padding="2dp"
            android:src="@drawable/ic_refresh"
            android:importantForAccessibility="no" />
    </LinearLayout>

    <!-- 中间行：左工位 + 中心盈亏 + 右工位(weight=1 等分) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="4dp">

        <!-- 工位 0 (左上) -->
        <LinearLayout
            android:id="@+id/row_0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_station_card"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <Chronometer
                android:id="@+id/timer_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:countDown="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/status_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/widget_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/station_name_0"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/item_name_0"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 中央盈亏 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.4"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_profit_banner"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今日盈亏"
                android:textColor="@color/widget_text_secondary"
                android:textSize="9sp"
                android:singleLine="true" />

            <TextView
                android:id="@+id/profit_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:gravity="center"
                android:text="--"
                android:textColor="@color/widget_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- 工位 1 (右上) -->
        <LinearLayout
            android:id="@+id/row_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_station_card"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:visibility="gone">

            <Chronometer
                android:id="@+id/timer_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:countDown="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/status_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/widget_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/station_name_1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/item_name_1"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- 下行：工位 2 + 工位 3(均分底部) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/row_2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_station_card"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:visibility="gone">

            <Chronometer
                android:id="@+id/timer_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:countDown="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/status_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/widget_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/station_name_2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/item_name_2"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_station_card"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:visibility="gone">

            <Chronometer
                android:id="@+id/timer_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:countDown="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/status_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/widget_text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                android:singleLine="true" />

            <TextView
                android:id="@+id/station_name_3"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <TextView
                android:id="@+id/item_name_3"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>