<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Android 13+ 运行时通知权限（spec 7.4/9.1） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 设备重启后恢复 WorkManager 周期同步（spec 12.4 可靠性） -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".DfApp"
        android:allowBackup="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.DfCrafting"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.DfCrafting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 通知按钮触发的 receiver（spec 7.4 暂停/打开/重新登录 快捷操作） -->
        <receiver
            android:name=".notify.NotificationActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.local.dfcraftmonitor.notify.PAUSE_SYNC" />
                <action android:name="com.local.dfcraftmonitor.notify.RESUME_SYNC" />
                <action android:name="com.local.dfcraftmonitor.notify.RELOGIN" />
            </intent-filter>
        </receiver>

        <!-- 桌面卡片 receiver（spec 8.1 Glance 4×2） -->
        <receiver
            android:name=".widget.CraftingWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/crafting_widget_info" />
        </receiver>
    </application>
</manifest>
